modules = ["nodejs-20", "python-3.11"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Web Interface"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Hardhat Node"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Deploy Contracts"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Demo Setup Check"

[[workflows.workflow]]
name = "Web Interface"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[[workflows.workflow]]
name = "Hardhat Node"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat node --hostname 0.0.0.0 --port 8545"
waitForPort = 8545

[[workflows.workflow]]
name = "Deploy Contracts"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat run scripts/deploy-and-setup.ts --network localhost"

[[workflows.workflow]]
name = "Demo Setup Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx hardhat run scripts/quick-setup-demo.ts --network localhost"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8545
externalPort = 3001

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "start.js"]
